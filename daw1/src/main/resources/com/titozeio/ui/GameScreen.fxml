<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="rootPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="720.0" prefWidth="1280.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.titozeio.ui.GameScreen">
   <children>
      
      <!-- Fondo base (textura o rejilla scifi) -->
      <ImageView fx:id="battlefieldBg" fitHeight="720.0" fitWidth="1280.0" opacity="1.0" pickOnBounds="true">
         <image>
            <Image url="@../images/bg2.jpg" />
         </image>
      </ImageView>

      <!-- Capa del Mapa: Donde se renderizarán los Hexágonos -->
      <StackPane fx:id="mapContainer">
         <children>
      <Pane fx:id="hexMapPane" prefHeight="720.0" prefWidth="1280.0" />
         </children>
      </StackPane>

      <!-- Capa de HUD: Elementos de interfaz activos -->
      <!-- pickOnBounds=false → los clics en el área central (vacía) pasan al mapa -->
      <BorderPane fx:id="mainHUD" mouseTransparent="false" pickOnBounds="false">
         <top>
            <HBox alignment="CENTER_LEFT" prefHeight="60.0" prefWidth="1280.0" spacing="20.0" style="-fx-background-color: rgba(11, 22, 28, 0.7); -fx-border-color: #4EE2C9; -fx-border-width: 0 0 1 0;" BorderPane.alignment="CENTER">
               <children>
                  <VBox alignment="CENTER_LEFT" prefHeight="200.0" prefWidth="100.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Label fx:id="turnLabel" text="TURNO 1 - JUGADOR 1" textFill="#4ee2c9">
                           <font>
                              <Font name="Exo 2 Bold" size="24.0" />
                           </font>
                        </Label>
                        <Label fx:id="objectiveShortLabel" text="Objetivo: Eliminar enemigos" textFill="#b2b2b2">
                           <font>
                              <Font name="Exo 2 Regular" size="12.0" />
                           </font>
                        </Label>
                     </children>
                  </VBox>
               </children>
               <padding>
                  <Insets left="20.0" right="20.0" />
               </padding>
            </HBox>
         </top>
         
         <bottom>
            <HBox alignment="BOTTOM_CENTER" prefHeight="180.0" prefWidth="1280.0" spacing="20.0" BorderPane.alignment="CENTER">
               <children>
                  
                  <!-- Panel de Información (Hover) -->
                  <VBox fx:id="infoPanel" prefHeight="160.0" prefWidth="350.0" spacing="5.0" styleClass="scifi-panel">
                     <children>
                        <Label text="INFORMACIÓN" textFill="#4ee2c9">
                           <font>
                              <Font name="Exo 2 Bold" size="14.0" />
                           </font>
                        </Label>
                        <Region prefHeight="1.0" prefWidth="200.0" style="-fx-background-color: #4EE2C9; -fx-opacity: 0.3;" />
                        <Label fx:id="infoDetailsLabel" alignment="TOP_LEFT" prefHeight="110.0" prefWidth="330.0" text="info" textFill="#e1e1e1" wrapText="true">
                           <font>
                              <Font name="Exo 2 Light" size="13.0" />
                           </font>
                        </Label>
                     </children>
                     <padding>
                        <Insets bottom="10.0" left="15.0" right="15.0" top="10.0" />
                     </padding>
                  </VBox>

                  <!-- Registro de Combate (Log) -->
                  <VBox prefHeight="200.0" prefWidth="100.0" spacing="5.0" style="-fx-background-color: rgba(0, 0, 0, 0.4); -fx-background-radius: 6;" HBox.hgrow="ALWAYS">
                     <children>
                        <Label text="LOG DE COMBATE" textFill="#949494">
                           <font>
                              <Font name="Exo 2 Regular" size="10.0" />
                           </font>
                        </Label>
                        <ScrollPane fx:id="logScrollPane" fitToWidth="true" hbarPolicy="NEVER" prefHeight="130.0" vbarPolicy="ALWAYS">
                           <content>
                              <VBox fx:id="combatLogContent" spacing="2.0">
                                 <!-- Las líneas de log se añadirán aquí dinámicamente -->
                              </VBox>
                           </content>
                        </ScrollPane>
                     </children>
                     <padding>
                        <Insets bottom="5.0" left="10.0" right="10.0" top="5.0" />
                     </padding>
                  </VBox>

                  <!-- Acciones de Juego -->
                  <VBox alignment="BOTTOM_CENTER" prefHeight="160.0" prefWidth="220.0" spacing="10.0">
                     <children>
                        <Button fx:id="skillButton" mnemonicParsing="false" prefHeight="40.0" prefWidth="220.0" styleClass="scifi-button-outline" text="SKILL">
                           <font>
                              <Font name="Exo 2 Bold" size="13.0" />
                           </font>
                        </Button>
                        <Button fx:id="endTurnButton" mnemonicParsing="false" prefHeight="50.0" prefWidth="220.0" styleClass="scifi-button" text="FINALIZAR TURNO">
                           <font>
                              <Font name="Exo 2 Bold" size="16.0" />
                           </font>
                        </Button>
                     </children>
                  </VBox>
               </children>
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" />
               </padding>
            </HBox>
         </bottom>
      </BorderPane>

      <!-- Capa de Mensajes Overlay (Modales) -->
      <StackPane fx:id="overlayPane" visible="false">
         <children>
            <Pane opacity="0.75" style="-fx-background-color: black;" />
            <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="300.0" prefWidth="500.0" spacing="30.0" styleClass="scifi-panel">
               <children>
                  <Label fx:id="overlayTitle" text="MENSAJE DEL SISTEMA" textFill="#4ee2c9">
                     <font>
                        <Font name="Exo 2 Bold" size="28.0" />
                     </font>
                  </Label>
                  <Label fx:id="overlayMessage" alignment="CENTER" text="Objetivos del mapa: Eliminar a todos los enemigos." textAlignment="CENTER" textFill="WHITE" wrapText="true">
                     <font>
                        <Font name="Exo 2 Regular" size="16.0" />
                     </font>
                  </Label>
                  <Button fx:id="overlayAcceptButton" mnemonicParsing="false" prefHeight="40.0" prefWidth="150.0" styleClass="scifi-button" text="ACEPTAR">
                     <font>
                        <Font name="Exo 2 Bold" size="14.0" />
                     </font>
                  </Button>
               </children>
               <padding>
                  <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
               </padding>
            </VBox>
         </children>
      </StackPane>

      <!-- Overlay de Victoria / Derrota -->
      <StackPane fx:id="victoryPane" visible="false">
         <children>
            <Pane opacity="0.88" style="-fx-background-color: #000814;" />
            <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="400.0" prefWidth="560.0" spacing="24.0" styleClass="scifi-panel">
               <children>
                  <!-- Emoji resultado -->
                  <Label fx:id="victoryIcon" text="🏆" style="-fx-font-size: 56px;" />
                  <!-- Título ganador -->
                  <Label fx:id="victoryTitle" text="¡VICTORIA!" textFill="#f5c518" wrapText="true">
                     <font>
                        <Font name="Exo 2 Bold" size="36.0" />
                     </font>
                  </Label>
                  <!-- Motivo -->
                  <Label fx:id="victoryReason" alignment="CENTER" text="Has eliminado a todos los robots enemigos." textAlignment="CENTER" textFill="#e1e1e1" wrapText="true">
                     <font>
                        <Font name="Exo 2 Regular" size="16.0" />
                     </font>
                  </Label>
                  <!-- Turno final -->
                  <Label fx:id="victoryTurnLabel" text="Turno 0" textFill="#4ee2c9">
                     <font>
                        <Font name="Exo 2 Light" size="13.0" />
                     </font>
                  </Label>
                  <!-- Acción -->
                  <Button fx:id="victoryMenuButton" mnemonicParsing="false" prefHeight="44.0" prefWidth="200.0" styleClass="scifi-button" text="VOLVER AL MENÚ">
                     <font>
                        <Font name="Exo 2 Bold" size="14.0" />
                     </font>
                  </Button>
               </children>
               <padding>
                  <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
               </padding>
            </VBox>
         </children>
      </StackPane>

   </children>
</StackPane>
