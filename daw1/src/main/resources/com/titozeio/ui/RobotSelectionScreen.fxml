<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.text.TextFlow?>

<!--
   RobotSelectionScreen.fxml — Pantalla de selección de robots.

   Las tarjetas de robot se generan dinámicamente en Java cargando
   RobotCard.fxml una vez por robot. El panel availableRobotsPane
   se deja vacío aquí intencionadamente.

   Para editar el diseño de las tarjetas → abre RobotCard.fxml en SceneBuilder.
   Para editar el resto de la pantalla → edita este archivo.
-->
<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.titozeio.ui.RobotSelectionScreen">
   <children>

      <!-- Imagen de fondo -->
      <ImageView fitHeight="720.0" fitWidth="1280.0" pickOnBounds="true">
         <image>
            <Image url="@../images/bg1.png" />
         </image>
         <StackPane.margin>
            <Insets />
         </StackPane.margin>
      </ImageView>

      <!-- Contenido principal -->
      <VBox alignment="CENTER" spacing="5.0" stylesheets="@style.css">
         <children>

            <!-- Título fijo -->
            <Label alignment="TOP_CENTER" prefHeight="0.0"
                   text="Pantalla de Selección de Robots"
                   textAlignment="CENTER" textFill="WHITE">
               <font>
                  <Font name="Exo 2 Regular" size="30.0" />
               </font>
            </Label>

            <!-- Instrucción general (fija) -->
            <Label fx:id="fixedInstructionsLabel"
                   alignment="TOP_CENTER"
                   text="Los jugadores eligen robots por turnos. Empieza J2. J1 realizará el primer turno de la partida"
                   textFill="#c9c9c9" wrapText="true">
               <font>
                  <Font name="Exo 2 Regular" size="20.0" />
               </font>
            </Label>

            <!-- Instrucción de turno actual (dinámica) -->
            <Label fx:id="turnInstructionsLabel"
                   text="Jugador 2, elige robot"
                   textFill="#c9c9c9">
               <font>
                  <Font size="16.0" />
               </font>
            </Label>

            <!--
               Panel de tarjetas de robots.
               Se rellena en tiempo de ejecución cargando RobotCard.fxml
               una vez por cada RobotTemplate disponible.
            -->
            <FlowPane fx:id="availableRobotsPane"
                      alignment="CENTER"
                      columnHalignment="CENTER"
                      hgap="20.0" vgap="10.0">
               <!-- Vacío intencionadamente: lo rellena RobotSelectionScreen.java -->
            </FlowPane>

            <!--
               Panel de descripción inferior.
               Oculto por defecto (visible="false").
               Aparece al hacer clic en una tarjeta de robot.
            -->
            <FlowPane fx:id="descriptionPane"
                      minHeight="130.0" prefHeight="130.0" maxHeight="130.0"
                      style="-fx-background-color: rgba(11, 22, 28, 1); -fx-background-radius: 6;"
                      visible="false">
               <VBox.margin>
                  <Insets />
               </VBox.margin>
               <children>

                  <!-- Descripción del robot -->
                  <TextFlow prefHeight="43.0" prefWidth="1239.0">
                     <padding>
                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                     </padding>
                     <children>
                        <Text fill="#910000" strokeType="OUTSIDE" strokeWidth="0.0" text="DESCRIPCIÓN:  ">
                           <font><Font name="Exo 2 Regular" size="16.0" /></font>
                        </Text>
                        <Text fx:id="descRobotText"
                              fill="#b3b3b3" strokeType="OUTSIDE" strokeWidth="0.0"
                              text="" wrappingWidth="1175.0">
                           <font><Font name="Exo 2 Regular" size="14.0" /></font>
                        </Text>
                     </children>
                  </TextFlow>

                  <!-- Descripción del arma -->
                  <TextFlow prefHeight="25.0" prefWidth="1239.0">
                     <padding>
                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                     </padding>
                     <children>
                        <Text fill="#910000" strokeType="OUTSIDE" strokeWidth="0.0" text="ARMA:  ">
                           <font><Font name="Exo 2 Regular" size="16.0" /></font>
                        </Text>
                        <Text fx:id="descWeaponText"
                              fill="#b3b3b3" strokeType="OUTSIDE" strokeWidth="0.0" text="">
                           <font><Font name="Exo 2 Regular" size="14.0" /></font>
                        </Text>
                     </children>
                  </TextFlow>

                  <!-- Descripción de la skill -->
                  <TextFlow prefHeight="39.0" prefWidth="1239.0">
                     <padding>
                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                     </padding>
                     <FlowPane.margin>
                        <Insets bottom="5.0" />
                     </FlowPane.margin>
                     <children>
                        <Text fill="#910000" strokeType="OUTSIDE" strokeWidth="0.0" text="SKILL:   ">
                           <font><Font name="Exo 2 Regular" size="16.0" /></font>
                        </Text>
                        <Text fx:id="descSkillText"
                              fill="#b3b3b3" strokeType="OUTSIDE" strokeWidth="0.0" text="">
                           <font><Font name="Exo 2 Regular" size="14.0" /></font>
                        </Text>
                     </children>
                  </TextFlow>

               </children>
            </FlowPane>

            <!--
               Botón Confirmar.
               Desactivado y semitransparente por defecto.
               Se activa al hacer clic en una tarjeta.
               Registra la selección al pulsarlo.
            -->
            <Button fx:id="confirmButton"
                    contentDisplay="CENTER"
                    disable="true"
                    opacity="0.35"
                    mnemonicParsing="false"
                    onAction="#handleConfirmAction"
                    style="-fx-font-size: 24; -fx-padding: 0 0; -fx-base: #2ecc71; -fx-text-fill: white; -fx-cursor: hand; -fx-background-color: transparent;"
                    text="Confirmar"
                    textAlignment="CENTER">
               <font>
                  <Font name="Exo 2" size="24.0" />
               </font>
               <graphic>
                  <ImageView fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@boton_1.png" />
                     </image>
                  </ImageView>
               </graphic>
            </Button>

         </children>
         <padding>
            <Insets left="20.0" right="20.0" />
         </padding>
         <StackPane.margin>
            <Insets bottom="10.0" />
         </StackPane.margin>
      </VBox>

   </children>
</StackPane>
